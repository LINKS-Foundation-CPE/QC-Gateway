BASE_DOMAIN=example.com
JOB_PORTAL_API_URL=api.example.com
DASHBOARD_URL=dashboard.example.com
FRONTEND_URL=spark.example.com
URL=spark.example.com
EXTRA_DOMAINS=dashboard.example.com,api.example.com,store.example.com,grafana.example.com
MACHINE_URL=https://machine.internal
IQM_SERVER_TOKEN=<TOKEN>
AUTH_URL=https://auth.example.com/auth
MINIO_ROOT_USER=rootadmin
MINIO_ROOT_PASSWORD=rootpass123
MINIO_SERVER_URL=https://store.example.com
MINIO_STORAGE_PATH=./minio-data
BUCKET_NAME=monitoring-data
APP_USER=tenantuser
APP_PASSWORD=tenantpass123
AWS_ACCESS_KEY_ID=<REDACTED>
AWS_SECRET_ACCESS_KEY=<REDACTED>
CALIBRATION_POLL_INTERVAL=3600

# PostgreSQL credentials for the local jobs database (used by the
# postgres, fastapi-proxy, and reporter services in docker-compose.yaml).
POSTGRES_PASSWORD=<CHANGE_ME>

# S3 endpoint (host:port) used by restic and volumes-backup for off-site
# backups of MinIO data and the Postgres volume. Example: backup.example.com:8010
BACKUP_ENDPOINT=<HOST:PORT>